{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/app/(.*)", "dest": "/api/app/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/ai.js":              { "maxDuration": 120 },
    "api/webhook.js":         { "maxDuration": 30 },
    "api/save-deployment.js": { "maxDuration": 30 },
    "api/app/[id].js":        { "maxDuration": 10 }
  }
}
